# App
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Database
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://rag:rag@postgres:5432/rag

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Vector Store (MVP: Chroma)
VECTOR_STORE_PROVIDER=chroma
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=rag_chunks

# Embedding (default: BGE)
EMBEDDING_PROVIDER=bge
BGE_MODEL_NAME=BAAI/bge-m3
BGE_DEVICE=cpu

# LLM (default: MiMo; config-driven)
LLM_PROVIDER=mimo
MIMO_BASE_URL=https://api.mimo.example/v1
MIMO_MODEL=mimo-chat
MIMO_API_KEY=replace_me
MIMO_TIMEOUT_SECONDS=60

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./data/files

# Auth (dev mode)
DEV_AUTH_TOKEN=
